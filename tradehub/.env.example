# PostgreSQL (обязательно на сервере — без этого сайт вернёт 503, моки не подставляются)
# Пример VPS: postgres://USER:PASSWORD@127.0.0.1:5432/tradehub
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# После первого деплоя на сервере: cd /opt/tradehub && npm run db:push && npm run db:seed
# Затем в /admin/groups добавьте Telegram-группы и при необходимости нажмите «Запустить сейчас» для парсера.

# Telegram API — нужны только для сценариев с MTProto; embed-парсер (sync) использует публичные t.me страницы
TG_API_ID="your_api_id_here"
TG_API_HASH="your_api_hash_here"
TG_SESSION="run_npm_run_parser_auth_to_get_this"

# Admin panel (/admin/groups)
ADMIN_KEY="set_strong_admin_key_here"
