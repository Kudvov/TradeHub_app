# PostgreSQL (обязательно на сервере — без этого сайт вернёт 503, моки не подставляются)
# Локально: только docker-compose.yml (старый compose.yaml с root/local удалён — иначе был конфликт).
# npm run db:up — затем:
# DATABASE_URL="postgres://teleposter:teleposter@127.0.0.1:5432/teleposter?sslmode=disable"
# Пример VPS: postgres://USER:PASSWORD@127.0.0.1:5432/teleposter
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# После первого деплоя на сервере: cd /opt/teleposter && npm run db:push && npm run db:seed
# Затем в /admin/groups добавьте Telegram-группы и при необходимости нажмите «Запустить сейчас» для парсера.

# Опционально: исходящий HTTP(S) прокси для embed-парсера (запросы к t.me). Полезно, если VPS режут по IP.
# Приоритет: PARSER_HTTPS_PROXY → HTTPS_PROXY → https_proxy. Пример: http://user:pass@proxy.example.com:8080
# PARSER_HTTPS_PROXY=
# HTTPS_PROXY=

# Календарные фильтры «Сегодня / Вчера / …» на ленте города: IANA-зона для даты поста (published_at). По умолчанию Asia/Tbilisi.
# LISTINGS_PERIOD_TIMEZONE=Asia/Tbilisi

# Синхронизация Telegram (parser:sync): пауза между запросами к t.me, мс. Меньше — быстрее; при росте 429 увеличьте.
# SYNC_MESSAGE_GAP_MS=220
# Пауза в бинарном поиске «последнего ID» новой группы, мс
# SYNC_PROBE_GAP_MS=100
# Как часто писать last_message_id в БД (1 = каждое объявление; 12 — по умолчанию, быстрее)
# SYNC_CURSOR_FLUSH_EVERY=12

# Рефреш фото после синка (npm run parser:refresh-images): сначала HEAD/GET по сохранённым URL; при «протухании» — полный репарс поста с t.me.
# REFRESH_PROBE_FIRST=0 — старое поведение: каждый раз скрапить embed и обновлять только если список URL изменился.
# REFRESH_EMPTY_IMAGES=1 — если в БД нет фото, всё равно скрапить embed (подтянуть картинки).
# REFRESH_IMAGE_PROBE_MAX=8 — сколько URL из объявления проверять. REFRESH_PROBE_GAP_MS=80 — пауза между проверками.

# Telegram API — нужны только для сценариев с MTProto; embed-парсер (sync) использует публичные t.me страницы
TG_API_ID="your_api_id_here"
TG_API_HASH="your_api_hash_here"
TG_SESSION="run_npm_run_parser_auth_to_get_this"

# Публичный URL сайта (если формы в админке дают «Cross-site POST forbidden» за reverse-proxy без X-Forwarded-Proto):
# ORIGIN="http://127.0.0.1:3000"

# Admin panel (/admin/groups)
ADMIN_KEY="set_strong_admin_key_here"
# Опционально: логин для входа в админку (по умолчанию: admin)
# ADMIN_LOGIN="admin"

# Мониторинг ошибок (Sentry) — опционально. Получить DSN: https://sentry.io
# Серверный DSN (server-side errors):
# SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/YYY"
# Клиентский DSN (browser errors, PUBLIC_ = виден клиенту):
# PUBLIC_SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/YYY"

# Google Gemini API — классификатор, экстрактор полей (parser:sync), переводы (parser:translate).
# Без ключа: regex в экстракторе; классификатор — категория other, без REJECT; переводы не запустятся.
# Ключ: https://aistudio.google.com/apikey
# GEMINI_API_KEY="..."
# Опционально модель (по умолчанию gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash-lite

# Локальная разработка: DEV_ALLOW_MOCK=0 — не подставлять тестовые объявления при ошибке БД (покажется 503)
# DEV_ALLOW_MOCK=0

# AI-реклассификация (npm run parser:ai-reclassify): по умолчанию только status=active.
# Вся таблица listings: AI_RECLASSIFY_ALL=1 npm run parser:ai-reclassify
# Сухой прогон: DRY_RUN=1 npm run parser:ai-reclassify

# Парсер: отключить фильтр стоп-слов (только отладка; на продакшене не оставлять включённым)
# TELEGRAM_STOP_WORDS_DISABLED=1
# Локальный Typograf для title/description при parser:sync (npm typograf). Отключить: 1
# TELEGRAM_TYPOGRAF_DISABLED=1
